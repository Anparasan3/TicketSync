# ──────────────────────────────────────────────
# Jira
# ──────────────────────────────────────────────
# Your Atlassian domain, e.g. https://mycompany.atlassian.net
JIRA_BASE_URL=https://yourcompany.atlassian.net

# The email you log into Jira with
JIRA_EMAIL=you@example.com

# Create an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-jira-api-token

# The Jira project key to watch, e.g. ENG, DEV, PROJ
JIRA_PROJECT_KEY=PROJ

# ──────────────────────────────────────────────
# Polling
# ──────────────────────────────────────────────
# How often to poll Jira in milliseconds (default: 300000 = 5 minutes)
POLL_INTERVAL_MS=300000

# ──────────────────────────────────────────────
# CSV output
# ──────────────────────────────────────────────
# Local path to write the CSV file
CSV_FILE_PATH=tickets.csv

# ──────────────────────────────────────────────
# GitHub
# ──────────────────────────────────────────────
# Personal access token with repo scope
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# GitHub repo owner (username or org name)
GITHUB_OWNER=your-username

# GitHub repo name
GITHUB_REPO=your-repo

# Path inside the repo where the CSV lives
GITHUB_CSV_PATH=tickets.csv

# The base branch PRs will target
GITHUB_BASE_BRANCH=main

# ──────────────────────────────────────────────
# Email (Resend)
# ──────────────────────────────────────────────
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# Sender address (must be verified in Resend)
EMAIL_FROM=ticketsync@yourdomain.com

# Recipient(s) — comma-separated for multiple
EMAIL_TO=team@yourdomain.com,manager@yourdomain.com
